# Скопируйте этот файл в `.env` и подставьте свои значения.
# `.env` в .gitignore — секреты в репозиторий не попадут.
# docker compose автоматически читает `.env` из этой папки.

# --- ClickHouse (в контейнер БД не входит) ---
# CH_HOST:
#   - удалённый сервер / живая БД → его адрес (напр. clickhouse.example.com);
#   - БД на ЭТОЙ ЖЕ машине (локальный дамп) → host.docker.internal
#     (внутри контейнера localhost = сам контейнер, до хоста им не достучаться).
CH_HOST=host.docker.internal
CH_PORT=8123
CH_USER=default
CH_PASSWORD=qwerty
CH_DB=eywa

# --- PostgreSQL (torch) — сигналы арбитража для страницы «Сигналы» ---
# ВНИМАНИЕ: дашборд в Postgres НЕ ходит. Сигналы читает сам ClickHouse (табличной
# функцией postgresql()) и материализует их у себя, поэтому адрес ниже — тот, по
# которому torch виден КОНТЕЙНЕРУ CLICKHOUSE, а не контейнеру дашборда. Если CH
# крутится на том же хосте, что и Postgres, это обычно адрес docker-шлюза
# (напр. 172.17.0.1) или host.docker.internal.
#
# Пароль попадёт в текст запроса к ClickHouse (так устроена postgresql()); в
# SHOW CREATE он маскируется. Если в пароле есть `$`, в .env его надо
# заэкранировать (`$$`) — иначе docker compose съест переменную.
CH_PG_HOST=host.docker.internal
CH_PG_PORT=5432
CH_PG_DB=torch
CH_PG_USER=postgres
CH_PG_PASSWORD=mysecretpassword

# --- Необязательно: материализация сигналов ---
# Период пересчёта (torch на аналитике обновляется репликацией раз в 4 часа).
# SIGNALS_REFRESH=1 HOUR
# Глубина: сигналы старше стольких дней не материализуем.
# SIGNALS_RETENTION_DAYS=90

# --- Порт, на котором дашборд публикуется на хост-машине ---
APP_PORT=5000

# --- Необязательно: USE_STUB=true — поднять контейнер на заглушках без БД (смоук-тест) ---
# USE_STUB=false
